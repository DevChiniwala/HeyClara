# HeyClara Environment Variables
# Copy to .env and fill in your values

# Database
DATABASE_URL=postgres://localhost:5432/clara

# Claude (primary AI backend)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_DM_USER_ID=...

# Twilio (SMS & WhatsApp)
TWILIO_SID=AC...
TWILIO_SECRET=...
TWILIO_AUTH_TOKEN=...
PRIMARY_PHONE_USER=+1...
PUBLIC_BASE_URL=https://your.domain.com

# Optional
OPENAI_API_KEY=sk-...    # For image generation
GEMINI_API_KEY=...        # For image generation
