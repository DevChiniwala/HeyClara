#!/usr/bin/env bun
"use strict";
const { join } = require("path");
const { existsSync } = require("fs");

// Find the project root by walking up from this binary
let root = __dirname;
for (let i = 0; i < 10; i++) {
  const candidate = join(root, "package.json");
  if (existsSync(candidate)) {
    require(join(root, "src", "cli", "index.ts"));
    return;
  }
  root = join(root, "..");
}

console.error("clara: could not find project root (package.json)");
process.exit(1);
