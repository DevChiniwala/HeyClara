{
  "name": "heyclara",
  "version": "0.5.0",
  "description": "A personal AI assistant daemon — chat, scheduled jobs, persona system, extensible via skills. Powered by Claude Agent SDK.",
  "type": "module",
  "scripts": {
    "start": "bun run src/cli/index.ts start",
    "stop": "bun run src/cli/index.ts stop",
    "status": "bun run src/cli/index.ts status",
    "dev": "bun run src/cli/index.ts run",
    "chat": "bun run src/cli/index.ts chat",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check:cycles": "madge --circular --extensions ts src/"
  },
  "bin": {
    "clara": "bin/clara"
  },
  "files": [
    "bin/",
    "src/",
    "defaults/",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "keywords": [
    "ai",
    "assistant",
    "agent",
    "daemon",
    "telegram",
    "slack",
    "cron",
    "claude",
    "clara"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "author": "Dev Chiniwala",
  "license": "MIT",
  "private": false,
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.190",
    "@anthropic-ai/sdk": "^0.105.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@slack/bolt": "^4.6.0",
    "commander": "^13.1.0",
    "cron-parser": "^5.5.0",
    "grammy": "^1.41.1",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/js-yaml": "^4.0.9",
    "madge": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
